<UserControl
    x:Class="Wauncher.Views.Controls.UpdateBarControl"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Wauncher.ViewModels"
    xmlns:svg="clr-namespace:Avalonia.Svg.Controls;assembly=Avalonia.Svg.Skia"
    mc:Ignorable="d"
    d:DesignWidth="1024"
    d:DesignHeight="80"
    x:DataType="vm:MainWindowViewModel">

    <Border
        Background="{DynamicResource AppRightPanelBg}"
        BorderBrush="{DynamicResource AppDivider}"
        BorderThickness="0,1,0,0"
        Padding="14,10">
        <Grid>

            <!-- Profile (left) -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal" Spacing="10">
                <Border Width="40" Height="40" Background="{DynamicResource AppInputBg}" ClipToBounds="True" CornerRadius="20">
                    <Image asyncImageLoader:ImageLoader.Source="{Binding ProfilePicture}" Stretch="UniformToFill" />
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryText}" Text="{Binding UsernameGreeting}" />
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Fill="{Binding WhitelistDotColor}" />
                        <TextBlock FontSize="11" Foreground="{DynamicResource AppBulletText}" Text="{Binding WhitelistText}" />
                    </StackPanel>
                    <TextBlock FontSize="11" Classes="selectedlabel" Classes.noserver="{Binding IsNoServerSelected}" Classes.serverselected="{Binding IsServerSelected}" Text="{Binding SelectedLabel}" />
                </StackPanel>
            </StackPanel>

            <!-- Buttons (right) -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                <!-- Info -->
                <Button Classes="iconBtn" Width="36" Height="36" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="Button_Info" CornerRadius="18" ToolTip.Tip="Info">
                    <Path Width="18" Height="18" Stretch="Uniform" Fill="White"
                          Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-6h2V17z M13,9h-2V7h2V9z" />
                </Button>
                <!-- Appearance -->
                <Button Classes="iconBtn" Width="36" Height="36" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="Button_Appearance" CornerRadius="18" ToolTip.Tip="Appearance">
                    <Path Width="18" Height="18" Stretch="Uniform"
                          Data="M7,14c-1.66,0-3,1.34-3,3c0,1.31-1.16,2-2,2c0.92,1.22,2.49,2,4,2c2.21,0,4-1.79,4-4C10,15.34,8.66,14,7,14z M20.71,4.63l-1.34-1.34c-0.39-0.39-1.02-0.39-1.41,0L9,12.25L11.75,15l8.96-8.96C21.1,5.65,21.1,5.02,20.71,4.63z"
                          Fill="White" />
                </Button>
                <!-- Settings -->
                <Button Classes="iconBtn" Width="36" Height="36" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="Button_Settings" CornerRadius="18" ToolTip.Tip="Settings">
                    <Path Width="18" Height="18" Stretch="Uniform" Fill="White"
                          Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
                </Button>
                <!-- Server selector -->
                <Button Classes="iconBtn serverSelectorBtn" Width="36" Height="36" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding ToggleServerDropdownCommand}" CornerRadius="18" IsEnabled="{Binding IsOnlineMode}" ToolTip.Tip="Select Server">
                    <Path Width="18" Height="18" Stretch="Uniform" Fill="White"
                          Data="F0 M3,3h18v5h-18z M5,4.5h2.5v2h-2.5z M3,9.5h18v5h-18z M5,11h2.5v2h-2.5z M3,16h18v5h-18z M5,17.5h2.5v2h-2.5z" />
                </Button>
                <!-- Launch button -->
                <Border CornerRadius="5" ClipToBounds="True" x:Name="LaunchButtonGlow" Classes="launchGlow" Classes.installPending="{Binding IsInstallPending}" Classes.updatePending="{Binding IsUpdatePending}" Classes.activeUpdate="{Binding UpdateService.IsUpdating}" Classes.activeInstall="{Binding IsInstallingOrChaining}" BoxShadow="0 0 18 2 #554CAF50">
                    <Grid>
                        <!-- Progress fill layers — clipped to CornerRadius by LaunchButtonGlow -->
                        <Border
                            IsVisible="{Binding IsUpdatingOrChaining}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="#FFC107"
                            RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="{Binding LaunchProgressScale}">
                                    <ScaleTransform.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="ScaleX" Duration="0:0:0.2" />
                                        </Transitions>
                                    </ScaleTransform.Transitions>
                                </ScaleTransform>
                            </Border.RenderTransform>
                        </Border>
                        <Border
                            IsVisible="{Binding UpdateService.IsInstalling}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="#2196F3"
                            RenderTransformOrigin="0,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="{Binding LaunchProgressScale}">
                                    <ScaleTransform.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="ScaleX" Duration="0:0:0.2" />
                                        </Transitions>
                                    </ScaleTransform.Transitions>
                                </ScaleTransform>
                            </Border.RenderTransform>
                        </Border>

                        <!-- Buttons on top of fill layers -->
                        <Grid ColumnDefinitions="*,1,32">
                            <Button x:Name="LaunchUpdateButton" Grid.Column="0" Classes="launchBtn" Classes.updating="{Binding IsUpdatingOrInstalling}" Classes.installPending="{Binding IsInstallPending}" Classes.updatePending="{Binding IsUpdatePending}" Padding="16,10" Width="155" HorizontalContentAlignment="Center" Command="{Binding LaunchGameCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Svg Width="15" Height="20" VerticalAlignment="Center" Path="/Assets/CS-logo.svg" IsVisible="{Binding !IsUpdatingOrInstalling}" />
                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource AppPrimaryText}" VerticalAlignment="Center" Text="{Binding LaunchButtonText}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Button>
                            <Rectangle Grid.Column="1" Fill="#40000000" />
                            <Button x:Name="ArrowButton" Grid.Column="2" Classes="launchBtn" Classes.updating="{Binding IsUpdatingOrInstalling}" Classes.installPending="{Binding IsInstallPending}" Classes.updatePending="{Binding IsUpdatePending}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <Button.Flyout>
                                    <MenuFlyout Placement="Top">
                                        <MenuItem Classes="compactFlyoutItem" Header="Verify Game Files" Command="{Binding ValidateFilesCommand}" />
                                        <MenuItem Classes="compactFlyoutItem" Header="Open Game Folder" Click="OpenGameFolder_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                                <Path Width="8" Height="5" Data="M0,5 L4,0 L8,5" Stroke="White" StrokeThickness="1.5" />
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
